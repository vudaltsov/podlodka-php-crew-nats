{
    "name": "phpyh/nats",
    "description": "Phpyh Nats",
    "type": "project",
    "authors": [
        {
            "name": "Valentin Udaltsov",
            "email": "udaltsov.valentin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "config": {
        "sort-packages": true,
        "bump-after-update": true
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Phpyh\\Nats\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpyh\\Nats\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "symfony/var-dumper": "^8.0"
    }
}
